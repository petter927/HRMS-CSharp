@*
    
*@
@{
    ViewData["Title"] = "出勤打卡";
}

<!-- 引入 Google Font & Font Awesome (若已全域引入可省略) -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:opsz@14..32&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">

<style>
    /* 頁面背景延續登入畫面的柔和橘色調 */
    body {
        background: #fef5e7;
        font-family: 'Inter', sans-serif;
    }

    /* 卡片設計：毛玻璃、大圓角、橘色陰影 */
    .punch-card {
        background: rgba(255, 255, 255, 0.85);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 36px;
        box-shadow: 0 25px 40px -12px rgba(230, 126, 34, 0.25), 0 10px 20px -8px rgba(0,0,0,0.1);
        overflow: hidden;
        margin-top: 2rem;
    }

    /* 卡片標題區：使用深橘色漸層 */
    .punch-header {
        background: linear-gradient(145deg, #e67e22, #d35400);
        padding: 1.5rem 2rem;
        color: white;
    }

    .punch-header h3 {
        font-weight: 600;
        font-size: 1.8rem;
        margin: 0;
        letter-spacing: -0.3px;
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .punch-header i {
        font-size: 2rem;
        opacity: 0.9;
    }

    /* 卡片主體 */
    .punch-body {
        padding: 2.5rem 2rem;
        text-align: center;
    }

    /* 歡迎訊息 */
    .welcome-message {
        font-size: 1.2rem;
        color: #4a4a4a;
        margin-bottom: 2rem;
        font-weight: 400;
    }

    .welcome-message strong {
        color: #e67e22;
        font-weight: 600;
    }

    /* 按鈕容器：使用 flex 讓按鈕在手機上也能適當排列 */
    .button-group {
        display: flex;
        justify-content: center;
        gap: 1.5rem;
        flex-wrap: wrap;
        margin: 2rem 0 1rem;
    }

    /* 通用按鈕樣式：圓角大、陰影、過渡效果 */
    .punch-btn {
        border: none;
        border-radius: 50px;
        padding: 1rem 2.5rem;
        font-size: 1.3rem;
        font-weight: 600;
        color: white;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
        min-width: 200px;
        transition: transform 0.15s, box-shadow 0.2s;
        box-shadow: 0 10px 18px rgba(0,0,0,0.1);
        cursor: pointer;
    }

    .punch-btn i {
        font-size: 1.4rem;
    }

    /* 上班按鈕：保留綠色系，但微調成更現代的色調 */
    .btn-checkin {
        background: linear-gradient(145deg, #2ecc71, #27ae60);
    }
    .btn-checkin:hover {
        transform: scale(1.03);
        background: linear-gradient(145deg, #27ae60, #1e8449);
        box-shadow: 0 15px 25px rgba(46, 204, 113, 0.4);
    }

    /* 下班按鈕：保留紅色系，調整成與橘色調和 */
    .btn-checkout {
        background: linear-gradient(145deg, #e67e22, #d35400); /* 與標題一致橘色，也可保留紅色 */
        /* 若想保留紅色，可改用以下 */
        /* background: linear-gradient(145deg, #e74c3c, #c0392b); */
    }
    .btn-checkout:hover {
        transform: scale(1.03);
        background: linear-gradient(145deg, #d35400, #b84a00);
        box-shadow: 0 15px 25px rgba(230, 126, 34, 0.4);
    }

    /* 卡片底部：伺服器時間 */
    .punch-footer {
        background: rgba(255, 255, 255, 0.4);
        backdrop-filter: blur(5px);
        -webkit-backdrop-filter: blur(5px);
        padding: 1rem 2rem;
        color: #4a4a4a;
        font-size: 1rem;
        border-top: 1px solid rgba(230, 126, 34, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
    }

    .punch-footer i {
        color: #e67e22;
    }

    /* 提示訊息樣式：配合整體設計 */
    .alert-custom {
        background: rgba(255, 255, 255, 0.9);
        border-left: 6px solid #e67e22;
        border-radius: 20px;
        box-shadow: 0 8px 16px rgba(230, 126, 34, 0.1);
        color: #2c3e50;
        font-weight: 500;
        padding: 1rem 1.8rem;
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 2rem;
    }

    .alert-custom i {
        font-size: 1.6rem;
        color: #e67e22;
    }

    /* 關閉按鈕調整 */
    .btn-close {
        filter: invert(0.5);
    }
</style>

<div class="container">
    <div class="punch-card">
        <!-- 卡片標題：使用橘色漸層，加入圖示 -->
        <div class="punch-header">
            <h3>
                <i class="fas fa-fingerprint"></i> <!-- 或 fa-clock、fa-calendar-check -->
                員工出勤登記
            </h3>
        </div>

        <!-- 卡片主體 -->
        <div class="punch-body">
            <!-- 成功訊息 (保留原有 TempData["Msg"] ) -->
            @if (TempData["Msg"] != null)
            {
                <div class="alert-custom alert-dismissible fade show" role="alert">
                    <i class="fas fa-check-circle"></i>
                    @TempData["Msg"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- 歡迎訊息，使用者名稱以橘色強調 -->
            <p class="welcome-message">
                <i class="fas fa-user-circle" style="color: #e67e22; margin-right: 6px;"></i>
                您好，<strong>@User.Identity.Name</strong>。請選擇打卡項目：
            </p>

            <!-- 按鈕群組 -->
            <div class="button-group">
                <!-- 上班打卡表單 -->
                <form asp-action="Punch" method="post" style="display: inline;">
                    <input type="hidden" name="type" value="上班" />
                    <button type="submit" class="punch-btn btn-checkin">
                        <i class="fas fa-sign-in-alt"></i> 上班打卡
                    </button>
                </form>

                <!-- 下班打卡表單 -->
                <form asp-action="Punch" method="post" style="display: inline;">
                    <input type="hidden" name="type" value="下班" />
                    <button type="submit" class="punch-btn btn-checkout">
                        <i class="fas fa-sign-out-alt"></i> 下班打卡
                    </button>
                </form>
            </div>
        </div>

        <!-- 卡片底部：伺服器時間加上圖示 -->
        <div class="punch-footer">
            <i class="fas fa-server"></i>
            目前伺服器時間：@DateTime.Now.ToString("yyyy-MM-dd HH:mm")
        </div>
    </div>
</div>